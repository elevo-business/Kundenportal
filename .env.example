PORT=3000
ADMIN_PASSWORD=dein-sicheres-passwort

# Google Drive Sync (optional)
# 1. Google Cloud Console → Projekt erstellen → Drive API aktivieren
# 2. Service Account erstellen → JSON Key downloaden
# 3. JSON Key als gdrive-credentials.json im App-Root ablegen (Coolify: File Mount nach /app/gdrive-credentials.json)
# 4. In Google Drive: Ordner erstellen, Service Account E-Mail als Editor einladen
# 5. Ordner-ID hier eintragen:
GDRIVE_PARENT_FOLDER_ID=
